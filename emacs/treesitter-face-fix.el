;;; Commentary:
;; This file solves the Emacs treesitter face timing issue where treesitter faces
;; (tree-sitter-hl-face:* and treesit-font-lock:*) are created dynamically when
;; `treesit-font-lock-mode` is first activated, not when themes load.
;;
;; Theme face definitions via `custom-theme-set-faces` are ignored if the faces
;; don't exist yet, causing syntax elements to appear as white text.
;;
;; This solution:
;; 1. Creates treesitter faces if they don't exist
;; 2. Applies theme colors to treesitter faces after theme loads
;; 3. Works with any theme that defines standard doom-theme color variables
;;
;; Usage:
;; Add to your Emacs config:
;; (load "~/dotfiles/emacs/treesitter-face-fix.el")

;;; Code:

(require 'doom-themes)

(defvar treesitter-face-fix--color-mapping
  '((green   . "green")
    (red     . "red")
    (cyan    . "cyan")
    (magenta . "magenta")
    (yellow  . "yellow")
    (orange  . "orange")
    (blue    . "blue")
    (grey    . "grey")
    (fg      . "fg")
    (comments . "comments"))
  "Mapping from theme color symbols to doom-color function names.")

(defun treesitter-face-fix--get-theme-color (color-symbol)
  "Get color value for COLOR-SYMBOL from current theme."
  (condition-case nil
      (doom-color color-symbol)
    (error
     (message "treesitter-face-fix: Could not get color for %s" color-symbol)
     nil)))

