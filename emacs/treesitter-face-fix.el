(defun treesitter-face-fix--verify-faces ()
  "Verify that treesitter faces have been colored."
  (let ((sample-faces '("tree-sitter-hl-face:keyword"
                        "tree-sitter-hl-face:string"
                        "tree-sitter-hl-face:comment"
                        "tree-sitter-hl-face:variable"
                        "treesit-font-lock:keyword"
                        "treesit-font-lock:string"
                        "treesit-font-lock:comment"
                        "treesit-font-lock:variable")))
    (dolist (face-name sample-faces)
      (let ((face-sym (intern face-name)))
        (when (facep face-sym)
          (let ((fg (face-foreground face-sym nil t)))
            (if fg
                (message "treesitter-face-fix: ✓ %s = %s" face-name fg)
              (message "treesitter-face-fix: ✗ %s has no foreground color" face-name))))))))

(defun treesitter-face-fix--apply-theme-faces (&rest _)
  "Apply treesitter faces after theme loads."
  (message "treesitter-face-fix: Applying treesitter faces for theme...")
  (treesitter-face-fix--create-treesitter-faces)
  
  ;; Apply theme-specific faces based on active theme
  (cond
   ((member 'doom-gruvbox-material custom-enabled-themes)
    (treesitter-face-fix--apply-gruvbox-material-faces)
    (message "treesitter-face-fix: Applied gruvbox-material treesitter faces")
    ;; Verify that faces have colors
    (treesitter-face-fix--verify-faces))
   ((member 'catppuccin custom-enabled-themes)
    ;; Catppuccin doesn't have treesitter faces in theme file
    ;; We'll apply a generic fallback using theme colors
    (message "treesitter-face-fix: Catppuccin theme loaded - no treesitter faces defined in theme"))
   (t
    (message "treesitter-face-fix: Unknown theme - treesitter faces may not be colored"))))

;; Add advice to enable-theme to apply treesitter faces after theme loads
(advice-add 'enable-theme :after #'treesitter-face-fix--apply-theme-faces)

;; Also run once now in case theme is already loaded
(when custom-enabled-themes
  (treesitter-face-fix--apply-theme-faces))

(provide 'treesitter-face-fix)

